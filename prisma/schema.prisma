generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReportStatus {
  PENDING
  CLAIMED
  RESOLVED
  DISMISSED
  APPROVED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  handle        String    @unique
  name          String?
  password      String?
  image         String?
  verifiedEmail Boolean   @default(false)
  emailVerified DateTime?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  reviews        Review[]
  reports        Report[]    @relation("ReportByUser")
  claimedReports Report[]    @relation("ReportClaims")
  accounts       Account[]
  sessions       Session[]
  adminLogs      AdminLog[]  @relation("AdminActions")
  adminNotes     AdminNote[] @relation("AdminNotes")
  userBadges     UserBadge[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  city      String?
  state     String?
  createdAt DateTime @default(now())

  reviews   Review[]
}

enum Seniority {
  JR
  PL
  SR
}

enum ContractType {
  CLT
  PJ
  ESTAGIO
  FREELA
}

enum WorkMode {
  REMOTO
  HIBRIDO
  PRESENCIAL
}

model Review {
  id            String       @id @default(uuid())
  companyId     String
  userId        String
  roleArea      String
  seniority     Seniority
  contractType  ContractType
  workMode      WorkMode
  year          Int?
  ratingOverall Int
  pros          String
  cons          String
  hidden        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company       Company      @relation(fields: [companyId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  reports       Report[]
}

model Report {
  id               String       @id @default(uuid())
  reviewId         String
  reporterUserId   String
  reason           String
  status           ReportStatus @default(PENDING)
  claimedByAdminId String?
  claimedAt        DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime     @default(now())

  review           Review       @relation(fields: [reviewId], references: [id])
  reporter         User         @relation("ReportByUser", fields: [reporterUserId], references: [id])
  claimedBy        User?        @relation("ReportClaims", fields: [claimedByAdminId], references: [id])

  @@index([status])
  @@index([claimedByAdminId])
}

model AdminNote {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation("AdminNotes", fields: [authorId], references: [id])

  @@index([authorId])
  @@index([createdAt])
}

enum BadgeAutoRule {
  NEW_ACCOUNT
}

model Badge {
  id          String         @id @default(uuid())
  name        String
  description String
  iconUrl     String
  color       String
  autoRule    BadgeAutoRule?
  createdAt   DateTime       @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  userId     String
  badgeId    String
  grantedAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  meta       String?
  createdAt  DateTime @default(now())

  admin      User     @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}
