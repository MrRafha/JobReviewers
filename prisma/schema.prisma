generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  handle        String
  verifiedEmail Boolean  @default(false)
  role          Role     @default(USER)
  createdAt     DateTime @default(now())

  reviews       Review[]
  reports       Report[] @relation("ReportByUser")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  city      String?
  state     String?
  createdAt DateTime @default(now())

  reviews   Review[]
}

enum Seniority {
  JR
  PL
  SR
}

enum ContractType {
  CLT
  PJ
  ESTAGIO
  FREELA
}

enum WorkMode {
  REMOTO
  HIBRIDO
  PRESENCIAL
}

model Review {
  id            String       @id @default(uuid())
  companyId     String
  userId        String
  roleArea      String
  seniority     Seniority
  contractType  ContractType
  workMode      WorkMode
  year          Int?
  ratingOverall Int
  pros          String
  cons          String
  hidden        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company       Company      @relation(fields: [companyId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  reports       Report[]
}

model Report {
  id             String   @id @default(uuid())
  reviewId       String
  reporterUserId String
  reason         String
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  review         Review   @relation(fields: [reviewId], references: [id])
  reporter       User     @relation("ReportByUser", fields: [reporterUserId], references: [id])
}
